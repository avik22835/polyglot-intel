# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Absolute path to the polyglot project you want to analyze.
# Windows example:  PROJECT_DIR=C:/Users/YourName/YourProject
# Mac/Linux example: PROJECT_DIR=/home/yourname/yourproject
#
# To run the built-in demo project (JS + Python + Rust + Ruby):
# PROJECT_DIR=C:/Users/KIIT0001/GSOC/smart-api-demo
PROJECT_DIR=C:/Users/YourName/YourProject

# Optional: only needed if running with --profile tunnel (ngrok public URL)
NGROK_AUTHTOKEN=your_ngrok_token_here
